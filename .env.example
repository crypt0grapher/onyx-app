# =============================================================================
# Onyx Frontend — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the required values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
#
# MAINNET is the default environment. The code defaults in config/goliath.ts
# and config/networks.ts target Goliath mainnet (chain 327) and Ethereum
# mainnet (chain 1) when no env overrides are present.
#
# For TESTNET, copy .env.testnet to .env.local instead (chain 8901 + Sepolia).

# -----------------------------------------------------------------------------
# Core / Required (obtain from respective dashboards)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_INFURA_API_KEY=

# Optional: Points API
# NEXT_PUBLIC_POINTS_API_URL=https://pnt.onyx.org/api/v1
# NEXT_PUBLIC_POINTS_SQUID_URL=https://pnt-squid.onyx.org/graphql

# Optional: TheGraph subgraph overrides
# NEXT_PUBLIC_SUBGRAPH_URL=
# NEXT_PUBLIC_SUBGRAPH_AUTH=

# =============================================================================
# Goliath Network (Mainnet — chain 327)
# =============================================================================
# All values below are optional. The code defaults (config/goliath.ts) already
# point to mainnet. Uncomment and override only if you need to change a value.

# -----------------------------------------------------------------------------
# Network basics (defaults: chain 327, rpc.goliath.net, validators.goliath.net)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GOLIATH_CHAIN_ID=327
# NEXT_PUBLIC_GOLIATH_RPC_URL=https://rpc.goliath.net
# NEXT_PUBLIC_GOLIATH_EXPLORER_URL=https://validators.goliath.net

# -----------------------------------------------------------------------------
# DEX contracts (mainnet defaults in config/goliath.ts)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GOLIATH_FACTORY_ADDRESS=0x008c99EedA17E193e5F788536234C6b3520B8D15
# NEXT_PUBLIC_GOLIATH_ROUTER_ADDRESS=0xa973c5626eEaF7F482439753953e9B28C6aF3674
# NEXT_PUBLIC_GOLIATH_MULTICALL3_ADDRESS=0x88b4BC8e5bd74327B5456466F3f30143986cC1f9
# NEXT_PUBLIC_GOLIATH_INIT_CODE_HASH=0x29ac827a7d364439c40cf6909f17f7f9144875302b275bae9498ac55cafc04ea

# -----------------------------------------------------------------------------
# Token addresses (Goliath mainnet — defaults in config/goliath.ts)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GOLIATH_WXCN_ADDRESS=0x1a0Da75ADf091a69E7285e596bB27218D77E17a9
# NEXT_PUBLIC_GOLIATH_USDC_ADDRESS=0xC8410270bb53f6c99A2EFe6eD3686a8630Efe22B
# NEXT_PUBLIC_GOLIATH_ETH_ADDRESS=0x9253587505c3B7E7b9DEE118AE1AcB53eEC0E4b6
# NEXT_PUBLIC_GOLIATH_BTC_ADDRESS=  # Not yet deployed on Goliath mainnet
# NEXT_PUBLIC_GOLIATH_XAUX_ADDRESS= # Not yet deployed on Goliath mainnet
# NEXT_PUBLIC_GOLIATH_XAGX_ADDRESS= # Not yet deployed on Goliath mainnet
# NEXT_PUBLIC_GOLIATH_USDT_ADDRESS= # Not yet deployed on Goliath mainnet
# NEXT_PUBLIC_GOLIATH_STXCN_ADDRESS= # Not yet deployed on Goliath mainnet

# -----------------------------------------------------------------------------
# Bridge — source chain (Ethereum mainnet, chain 1)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GOLIATH_SOURCE_CHAIN_ID=1
# NEXT_PUBLIC_GOLIATH_SOURCE_RPC_URLS=https://ethereum-rpc.publicnode.com
# NEXT_PUBLIC_GOLIATH_SOURCE_EXPLORER_URL=https://etherscan.io
# NEXT_PUBLIC_GOLIATH_SOURCE_BRIDGE_ADDRESS=0xa9fd64b5095d626f5a3a67e6db7fb766345f8092

# Bridge source tokens (Ethereum mainnet)
# NEXT_PUBLIC_GOLIATH_SOURCE_USDC_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
# NEXT_PUBLIC_GOLIATH_SOURCE_XCN_ADDRESS=0xA2cd3D43c775978A96BdBf12d733D5A1ED94fb18

# -----------------------------------------------------------------------------
# Bridge — Goliath side
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GOLIATH_BRIDGE_ENABLED=true
# NEXT_PUBLIC_GOLIATH_BRIDGE_ALLOW_CUSTOM_RECIPIENT=false
# NEXT_PUBLIC_GOLIATH_BRIDGE_ADDRESS=0x1d14ae13ca030eb5e9e2857e911af515cf5ffff2
# NEXT_PUBLIC_GOLIATH_BRIDGE_STATUS_API_URL=https://bridge.goliath.net/api/v1
# NEXT_PUBLIC_GOLIATH_BRIDGE_RELAYER_ADDRESS=0xE708B75F7b6914479E63D3897bEF9e0dedcA3640
# NEXT_PUBLIC_GOLIATH_BRIDGE_POLL_INTERVAL=5000
# NEXT_PUBLIC_GOLIATH_BRIDGE_MIN_AMOUNT=0.001

# -----------------------------------------------------------------------------
# Migration (source: Ethereum mainnet staking contract)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GOLIATH_MIGRATION_ENABLED=true
# NEXT_PUBLIC_GOLIATH_CLAIM_ENABLED=true
# NEXT_PUBLIC_GOLIATH_STATS_ENABLED=false
# NEXT_PUBLIC_GOLIATH_HISTORY_ENABLED=false
# NEXT_PUBLIC_GOLIATH_SOURCE_STAKING_ADDRESS=0x23445c63feef8d85956dc0f19ade87606d0e19a9
# NEXT_PUBLIC_GOLIATH_MIGRATION_DEADLINE=1800
# NEXT_PUBLIC_GOLIATH_MIGRATION_STATUS_POLL_MS=3000
# NEXT_PUBLIC_GOLIATH_MIGRATION_DATA_POLL_MS=15000

# -----------------------------------------------------------------------------
# Staking (Goliath liquid staking)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GOLIATH_STAKING_ENABLED=true
# NEXT_PUBLIC_GOLIATH_STAKING_PROTOCOL_POLL_MS=30000
# NEXT_PUBLIC_GOLIATH_STAKING_BALANCE_POLL_MS=15000
